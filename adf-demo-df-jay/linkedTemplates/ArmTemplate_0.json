				"annotations": [],
				"type": "SnowflakeV2",
				"typeProperties": {
					"authenticationType": "Basic",
					"accountIdentifier": "YYLITLD-OC81399",
					"user": "SAIJAY1509",
					"database": "[parameters('Snowflake1_properties_typeProperties_database')]",
					"warehouse": "XSMALL_WH",
					"password": {
						"type": "SecureString",
						"value": "[parameters('Snowflake1_password')]"
					},
					"useUtcTimestamps": false
				},
				"version": "1.1"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_adls_adfdemojayadlssa')]",
