{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-demo-df-jay"
		},
		"Snowflake1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Snowflake1'"
		},
		"ls_adls_adfdemojayadlssa_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_adfdemojayadlssa'"
		},
		"ls_azure_sql_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_azure_sql_db'"
		},
		"ls_blob_adfdemosajay_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_adfdemosajay'"
		},
		"ls_onprem_sql_server_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_onprem_sql_server'"
		},
		"Snowflake1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sample_db"
		},
		"ls_adls_adfdemojayadlssa_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adfdemojayadlssa.dfs.core.windows.net/"
		},
		"ls_azure_sql_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adf-demo-sql-server1-jay.database.windows.net"
		},
		"ls_azure_sql_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adf-demo-sql-db"
		},
		"ls_azure_sql_db_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "serveradmin"
		},
		"ls_onprem_sql_server_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "20.235.56.12"
		},
		"ls_onprem_sql_server_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "onPremDB"
		},
		"ls_onprem_sql_server_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "serveradmin12"
		},
		"ls_rest_api_emp_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "http://dummy.restapiexample.com/api/v1/employees"
		},
		"ls_stg_blob_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 'ls_stg_blob'"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-demo-df-jay_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Snowflake1_password": {
						"value": "[parameters('Snowflake1_password')]"
					},
					"ls_adls_adfdemojayadlssa_accountKey": {
						"value": "[parameters('ls_adls_adfdemojayadlssa_accountKey')]"
					},
					"ls_azure_sql_db_password": {
						"value": "[parameters('ls_azure_sql_db_password')]"
					},
					"ls_blob_adfdemosajay_connectionString": {
						"value": "[parameters('ls_blob_adfdemosajay_connectionString')]"
					},
					"Snowflake1_properties_typeProperties_database": {
						"value": "[parameters('Snowflake1_properties_typeProperties_database')]"
					},
					"ls_adls_adfdemojayadlssa_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_adfdemojayadlssa_properties_typeProperties_url')]"
					},
					"ls_azure_sql_db_properties_typeProperties_server": {
						"value": "[parameters('ls_azure_sql_db_properties_typeProperties_server')]"
					},
					"ls_azure_sql_db_properties_typeProperties_database": {
						"value": "[parameters('ls_azure_sql_db_properties_typeProperties_database')]"
					},
					"ls_azure_sql_db_properties_typeProperties_userName": {
						"value": "[parameters('ls_azure_sql_db_properties_typeProperties_userName')]"
					},
					"ls_rest_api_emp_properties_typeProperties_url": {
						"value": "[parameters('ls_rest_api_emp_properties_typeProperties_url')]"
					},
					"ls_stg_blob_sasUri": {
						"value": "[parameters('ls_stg_blob_sasUri')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-demo-df-jay_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_onprem_sql_server_password": {
						"value": "[parameters('ls_onprem_sql_server_password')]"
					},
					"ls_onprem_sql_server_properties_typeProperties_server": {
						"value": "[parameters('ls_onprem_sql_server_properties_typeProperties_server')]"
					},
					"ls_onprem_sql_server_properties_typeProperties_database": {
						"value": "[parameters('ls_onprem_sql_server_properties_typeProperties_database')]"
					},
					"ls_onprem_sql_server_properties_typeProperties_userName": {
						"value": "[parameters('ls_onprem_sql_server_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-demo-df-jay_ArmTemplate_0')]"
			]
		},
		{
			"name": "adf-demo-df-jay_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-demo-df-jay_ArmTemplate_1')]"
			]
		}
	]
}